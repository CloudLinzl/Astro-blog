---
import ArchiveList from '@/components/ArchiveList.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import Layout from '@/layouts/Layout.astro'
import { getTopLevelArchives } from '@/utils/content'

export async function getStaticPaths() {
  return allLocales.map(lang => ({
    params: { lang: getLangRouteParam(lang) },
  }))
}

const currentLang = getLangFromLocale(Astro.currentLocale)
const archives = await getTopLevelArchives(currentLang)
---

<Layout>
  <div class="uno-decorative-line" />
  <ArchiveList
    archives={archives}
    lang={currentLang}
  />
</Layout>
