---
import ArchiveBreadcrumb from '@/components/ArchiveBreadcrumb.astro'
import ArchiveList from '@/components/ArchiveList.astro'
import PostList from '@/components/PostList.astro'
import { allLocales } from '@/config'
import { getLangFromLocale, getLangRouteParam } from '@/i18n/lang'
import { getArchivePath } from '@/i18n/path'
import { ui } from '@/i18n/ui'
import Layout from '@/layouts/Layout.astro'
import {
  getAllArchiveNodePaths,
  getArchiveBreadcrumbs,
  getArchiveSupportedLangs,
  getDirectChildArchives,
  getPostsByArchive,
} from '@/utils/content'

export async function getStaticPaths() {
  const paths = await Promise.all(allLocales.map(async (lang) => {
    const archivePaths = await getAllArchiveNodePaths(lang)
    return archivePaths.map(archive => ({
      params: { lang: getLangRouteParam(lang), archive },
      props: { archive },
    }))
  }))

  return paths.flat()
}

const { archive } = Astro.props
const currentLang = getLangFromLocale(Astro.currentLocale)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}
const breadcrumbs = getArchiveBreadcrumbs(archive)
const childArchives = await getDirectChildArchives(archive, currentLang)
const posts = await getPostsByArchive(archive, currentLang)
const supportedLangs = await getArchiveSupportedLangs(archive)
const currentArchiveName = breadcrumbs[breadcrumbs.length - 1]?.name ?? archive
const parentArchive = breadcrumbs[breadcrumbs.length - 2]
const parentArchivePath = parentArchive?.path ?? ''
const parentArchiveName = parentArchive?.name ?? currentUI.archives
---

<Layout supportedLangs={supportedLangs}>
  <div class="mb-5.5">
    <a
      href={getArchivePath(parentArchivePath, currentLang)}
      class="no-heti inline-flex items-center gap-2 text-3.35 c-secondary/72 transition-colors hover:c-primary"
    >
      <span aria-hidden="true">←</span>
      <span>{parentArchiveName}</span>
    </a>
  </div>

  <ArchiveBreadcrumb
    items={breadcrumbs}
    lang={currentLang}
  />

  <section class="mb-7.5">
    <div class="mb-3.5 flex items-end justify-between gap-4">
      <h1 class="archive-page-title">
        {currentArchiveName}
      </h1>
      <span class="text-3.1 c-secondary/55 tracking-[0.18em] uppercase">
        {posts.length}
      </span>
    </div>
    <div class="uno-decorative-line" />
  </section>

  {childArchives.length > 0 && (
    <ArchiveList
      archives={childArchives}
      lang={currentLang}
    />
  )}

  {posts.length > 0 && (
    <PostList
      posts={posts}
      lang={currentLang}
    />
  )}
</Layout>

<style>
  .archive-page-title {
    font-size: 1.68rem;
    font-weight: 700;
    line-height: 1.12;
    color: oklch(var(--un-preset-theme-colors-primary));
  }

  @media (min-width: 1024px) {
    .archive-page-title {
      font-size: 1.92rem;
    }
  }
</style>
