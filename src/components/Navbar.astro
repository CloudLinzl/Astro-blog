---
import { ui } from '@/i18n/ui'
import { getPageInfo } from '@/utils/page'

const { currentLang, isHome, isPost, isTag, isArchive, isAbout, getLocalizedPath } = getPageInfo(Astro.url.pathname)
const currentUI = ui[currentLang as keyof typeof ui] ?? {}

const isArchiveActive = isHome || isArchive || isPost || isTag
const isAboutActive = isAbout

function getNavItemClass(isActive: boolean) {
  return isActive
    ? 'highlight-static c-primary font-bold after:bottom-0.7em'
    : 'highlight-hover transition-[colors,font-weight] after:bottom-0.7em hover:(c-primary font-bold)'
}

const navItems = [
  {
    href: '/archives/',
    label: currentUI.archives,
    className: getNavItemClass(isArchiveActive),
  },
  {
    href: '/about/',
    label: currentUI.about,
    className: getNavItemClass(isAboutActive),
  },
]
---

<nav
  aria-label="Site Navigation"
  class:list={[
    'mb-9.5 border-b border-secondary/12 pb-3.8 text-3.6 font-semibold leading-2.1em font-navbar',
    'cjk:tracking-wide lg:(mb-10.5 pb-4 text-4)',
  ]}
>
  <ul class="flex flex-wrap items-center gap-x-8 gap-y-2">
    {navItems.map(item => (
      <li>
        <a
          href={getLocalizedPath(item.href)}
          class={item.className}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
