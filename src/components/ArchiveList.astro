---
import type { Language } from '@/i18n/config'
import type { ArchiveLink } from '@/utils/content'
import { getArchivePath } from '@/i18n/path'

interface Props {
  archives: ArchiveLink[]
  currentArchive?: string
  lang: Language
}

const { archives, currentArchive = '', lang } = Astro.props
---

<ul class="mb-10.5">
  {archives.map(archive => (
    <li class="border-b border-secondary/12 py-3.2 last:border-b-0 lg:py-4.3">
      <a
        href={getArchivePath(archive.path, lang)}
        class:list={[
          'group flex items-end justify-between gap-4 transition-colors',
          currentArchive === archive.path ? 'c-primary' : 'c-secondary/92 hover:c-primary',
        ]}
      >
        <div class="min-w-0 flex-1">
          <div
            class:list={[
              'flex items-center gap-3',
              currentArchive === archive.path ? 'font-medium' : '',
            ]}
          >
            <span class="text-3.2 c-secondary/45 lg:text-3.5">/</span>
            <span class="archive-list-title truncate">
              {archive.name}
            </span>
          </div>
        </div>
        {typeof archive.count === 'number' && (
          <span class="shrink-0 text-3.2 c-secondary/62 font-time lg:text-3.5">
            {archive.count}
          </span>
        )}
      </a>
    </li>
  ))}
</ul>

<style>
  .archive-list-title {
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.25;
  }

  @media (min-width: 1024px) {
    .archive-list-title {
      font-size: 1.34rem;
    }
  }
</style>
